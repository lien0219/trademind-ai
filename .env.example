# =============================================================================
# TradeMind — copy to .env and adjust (never commit .env)
# =============================================================================

# Application
APP_ENV=development
APP_HTTP_ADDR=:8080
# AES-GCM master key for encrypting settings (64-char hex, base64 of 32 bytes, 32-char raw, or any passphrase hashed with SHA-256)
APP_MASTER_KEY=

# First admin when admin_users is empty: set EMAIL and/or PHONE (+ password).
# Login is email or mobile only — not by internal username (production: require ADMIN_BOOTSTRAP_PASSWORD).
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PHONE=
ADMIN_BOOTSTRAP_PASSWORD=

# -----------------------------------------------------------------------------
# Database (Gin main service) — 默认 PostgreSQL；可设 DB_DRIVER=mysql 使用 MySQL
# -----------------------------------------------------------------------------
DB_DRIVER=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=trademind
DB_PASSWORD=trademind
DB_NAME=trademind
DB_TIMEZONE=UTC

# -----------------------------------------------------------------------------
# Redis (queue / cache)
# -----------------------------------------------------------------------------
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# JWT / session (backend)
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=168

# 上传单文件最大体积（MB），默认 10
UPLOAD_MAX_MB=10

# -----------------------------------------------------------------------------
# 对象存储说明（不写环境变量也可用：在管理端「存储设置」写入 settings.storage）
# -----------------------------------------------------------------------------
# 本地示例：kind=local，local_root=data/uploads（相对路径解析到仓库根目录 data/uploads），public_base=/static
# TRADEMIND_REPO_ROOT=   # 可选；monorepo 根目录，未设置时从 backend 工作目录向上自动探测
# AWS S3 示例：kind=s3，s3_region=us-east-1，s3_bucket=your-bucket，s3_endpoint 留空则用默认分区
# Cloudflare R2：kind=r2，s3_endpoint=https://<account_id>.r2.cloudflarestorage.com，s3_region=auto
# MinIO：kind=minio，s3_endpoint=http://127.0.0.1:9000，s3_force_path_style=true，s3_public_base=http://127.0.0.1:9000/bucket 或网关/CDN 前缀
# 密钥：s3_access_key_id、s3_secret_access_key 仅存库（AES-GCM），勿写入本文件。
# 腾讯云 COS（原生 SDK）：kind=cos；cos_bucket=示例 myapp-1250000000（或裸桶名 myapp + cos_app_id=1250000000），cos_region=ap-guangzhou；
# cos_secret_id / cos_secret_key 仅存库加密；可选 cos_endpoint 自定义域；可选 cos_public_base 对外 CDN 前缀（否则用桶默认域名）；cos_use_https=true
# 阿里云 OSS（原生 SDK）：kind=oss；oss_endpoint=https://oss-cn-guangzhou.aliyuncs.com，oss_bucket=your-bucket；
# oss_access_key_id / oss_access_key_secret 仅存库加密；oss_public_base 建议填 CDN/Bucket 公网前缀；oss_use_https=true

# Go API → Node collector（编排采集；须与 COLLECTOR_HTTP_ADDR 端口一致）
COLLECTOR_BASE_URL=http://127.0.0.1:3100
COLLECTOR_TIMEOUT_SECONDS=60

# 采集异步队列（Redis LIST，Worker 消费；提交任务须 Redis 可用）
COLLECT_QUEUE_ENABLED=true
COLLECT_WORKER_CONCURRENCY=2
COLLECT_QUEUE_NAME=collect:tasks
# 单次批量采集最大 URL 数（POST /collect/batches）
COLLECT_BATCH_MAX_URLS=50

# 1688 批量采集保守节流（仅 bulk 任务；单链接采集不受影响）
COLLECT_BATCH_CONCURRENCY_1688=1
COLLECT_BATCH_DELAY_MIN_MS_1688=1500
COLLECT_BATCH_DELAY_MAX_MS_1688=5000
COLLECT_BATCH_RETRY_ON_BLOCKED=true
COLLECT_BATCH_RETRY_ON_TIMEOUT=true
COLLECT_BATCH_MAX_RETRIES_1688=2

# Worker 自动退避重试
COLLECT_AUTO_RETRY_ENABLED=true
COLLECT_MAX_RETRIES=3
COLLECT_RETRY_BASE_DELAY_SECONDS=30
COLLECT_RETRY_MAX_DELAY_SECONDS=600

# 图片任务异步队列（Redis LIST；POST /image/tasks 入队，进程内 Image Worker BRPOP 消费）
# IMAGE_QUEUE_ENABLED=false 时：创建接口在同请求内同步执行（仅建议本地开发）
IMAGE_QUEUE_ENABLED=true
IMAGE_QUEUE_NAME=image:tasks
IMAGE_WORKER_CONCURRENCY=2
# 单次任务 provider 调用 context 上限（秒），与 settings.image.timeout_sec 取更小值
IMAGE_TASK_TIMEOUT_SECONDS=120
# 失败进入 retrying + next_retry_at，由进程内调度器到期后 LPUSH（需 IMAGE_QUEUE_ENABLED=true）
IMAGE_AUTO_RETRY_ENABLED=true
IMAGE_MAX_RETRIES=2
IMAGE_RETRY_BASE_DELAY_SECONDS=30
IMAGE_RETRY_MAX_DELAY_SECONDS=300

# 订单同步异步队列（Redis LIST；Worker BRPOP；ORDER_SYNC_QUEUE_ENABLED=false 时创建后在 API 进程内同步执行）
ORDER_SYNC_QUEUE_ENABLED=true
ORDER_SYNC_QUEUE_NAME=order:sync:tasks
ORDER_SYNC_WORKER_CONCURRENCY=1
ORDER_SYNC_TASK_TIMEOUT_SECONDS=120

# 客服消息异步同步（Redis LIST；CUSTOMER_MESSAGE_SYNC_QUEUE_ENABLED=false 时由 API 进程内同步执行）
CUSTOMER_MESSAGE_SYNC_QUEUE_ENABLED=true
CUSTOMER_MESSAGE_SYNC_QUEUE_NAME=customer:message:sync:tasks
CUSTOMER_MESSAGE_SYNC_WORKER_CONCURRENCY=1
CUSTOMER_MESSAGE_SYNC_TASK_TIMEOUT_SECONDS=120

# 商品刊登异步队列（Redis LIST；PRODUCT_PUBLISH_QUEUE_ENABLED=false 时创建任务后在 API 进程内同步执行）
PRODUCT_PUBLISH_QUEUE_ENABLED=true
PRODUCT_PUBLISH_QUEUE_NAME=product:publish:tasks
PRODUCT_PUBLISH_WORKER_CONCURRENCY=1
PRODUCT_PUBLISH_TASK_TIMEOUT_SECONDS=180

# 库存同步异步队列（Redis LIST；Worker BRPOP；INVENTORY_SYNC_QUEUE_ENABLED=false 时任务在创建进程内同步执行）
INVENTORY_SYNC_QUEUE_ENABLED=true
INVENTORY_SYNC_QUEUE_NAME=inventory:sync:tasks
INVENTORY_SYNC_WORKER_CONCURRENCY=1
INVENTORY_SYNC_TASK_TIMEOUT_SECONDS=120

# 采集任务 DB 租约 TTL（多实例 Worker 回收；应 ≥ Collector 超时 + 余量）
COLLECT_TASK_TIMEOUT_SECONDS=600

# 多实例 Worker：实例注册表 + 心跳 + 任务租约 + Reaper（heartbeat 关闭时仍生成 workerId 并写 DB 租约，但不落 worker_instances）
WORKER_HEARTBEAT_ENABLED=true
WORKER_HEARTBEAT_INTERVAL_SECONDS=10
WORKER_STALE_AFTER_SECONDS=30
WORKER_REAPER_ENABLED=true
WORKER_REAPER_INTERVAL_SECONDS=15
WORKER_LEGACY_RUNNING_TIMEOUT_SECONDS=1800

# 任务告警：进程内定时扫描（非 Redis）。仅部署级门闸；业务是否启用与扫描间隔见管理端「系统设置」settings.taskcenter。
TASK_ALERT_SCAN_ENABLED=false
TASK_ALERT_SCAN_INTERVAL_SECONDS=60
TASK_ALERT_SCAN_LOOKBACK_MINUTES=120
TASK_ALERT_SCAN_LOCK_TTL_SECONDS=120
# 说明：收件邮箱、Webhook、通知阈值/等级/通道等均仅存 settings（taskcenter / alert_notify），请勿写入本文件。
# 告警邮件/Webhook 详情链接前缀、Webhook HTTP 超时见管理端「告警通知」「系统设置」。

# -----------------------------------------------------------------------------
# TikTok Shop Partner / Open Platform
# -----------------------------------------------------------------------------
# 「平台参数」不得在 .env 或仓库中写入真实密钥。请在管理端「设置 → 平台开放配置」维护分组 platform_tiktok
# （app_key 明文；app_secret 加密；auth_base_url、api_base_url、redirect_uri、api_version、timeout_sec 等）。
# 店铺 OAuth 的 access_token / refresh_token 仅存「店铺 → 授权」对应 shop_auth_tokens，勿写入此处。

# -----------------------------------------------------------------------------
# Node collector service (Playwright) — separate process from Go API
# -----------------------------------------------------------------------------
COLLECTOR_HTTP_ADDR=:3100
COLLECTOR_MAIN_SERVICE_URL=http://127.0.0.1:8080
# open page timeout (ms); navigation default same family
COLLECTOR_GOTO_TIMEOUT_MS=45000
# 1 or true = headless (default headless)
COLLECTOR_HEADLESS=1
# optional override; default ships a modern Chrome UA in browser/manager
# COLLECTOR_USER_AGENT=

# -----------------------------------------------------------------------------
# Admin frontend (Vite / Ant Design Pro — configure when wired)
# -----------------------------------------------------------------------------
# VITE_API_BASE=/api
