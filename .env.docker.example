# =============================================================================
# TradeMind — Docker 部署启动用环境变量示例
# 使用：复制为仓库根目录 `.env`（不要提交 `.env`）
#   cp .env.docker.example .env
# Windows PowerShell：Copy-Item .env.docker.example .env
#
# 警告（必读）：
# - 以下 JWT_SECRET / APP_MASTER_KEY / ADMIN_BOOTSTRAP_PASSWORD / 数据库密码等仅用于本地试用。
# - 生产环境必须改为强随机值；切勿将真实 AI Key、平台密钥、Webhook、邮箱密码写入仓库。
# =============================================================================

APP_ENV=development
# Gin ReleaseMode 由代码在 APP_ENV=production 时开启；此处 development 便于排查问题。
GIN_MODE=debug

# 后端监听（docker-compose.full.yml 内已固定为容器内 :8080；勿与宿主机映射混淆）
APP_HTTP_ADDR=:8080

# AES-GCM：须非空；示例为 64 位十六进制（32 字节）
APP_MASTER_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

JWT_SECRET=change_me_dev_jwt_secret_replace_in_production
JWT_EXPIRE_HOURS=168

ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PHONE=
ADMIN_BOOTSTRAP_PASSWORD=admin123456

# -----------------------------------------------------------------------------
# PostgreSQL（Compose postgres 服务 + GORM）
# -----------------------------------------------------------------------------
POSTGRES_DB=trademind
POSTGRES_USER=trademind
POSTGRES_PASSWORD=trademind_dev_password

DB_DRIVER=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USER=trademind
DB_PASSWORD=trademind_dev_password
DB_NAME=trademind
DB_TIMEZONE=UTC

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# Collector ↔ Backend（编排网络内服务名）
# -----------------------------------------------------------------------------
COLLECTOR_BASE_URL=http://collector:3001
COLLECTOR_TIMEOUT_SECONDS=120
# 容器内监听端口由 compose 固定为 3001（宿主机映射见 COLLECTOR_PUBLISH_PORT）
COLLECTOR_HTTP_ADDR=:3001
# 以下变量与 .env.example 对齐；当前 Collector 代码未读取 MAIN_SERVICE_URL。
COLLECTOR_MAIN_SERVICE_URL=http://backend:8080
COLLECTOR_GOTO_TIMEOUT_MS=45000
COLLECTOR_HEADLESS=1
# 1688 持久化浏览器 Profile（compose 已挂载 ./data/browser-profiles）
# COLLECTOR_BROWSER_PROFILE_DIR=/workspace/data/browser-profiles
# COLLECTOR_STORAGE_STATE_DIR=/workspace/data/storage-states

# -----------------------------------------------------------------------------
# 异步队列（与根目录 .env.example 默认对齐）
# -----------------------------------------------------------------------------
COLLECT_QUEUE_ENABLED=true
COLLECT_WORKER_CONCURRENCY=2
COLLECT_QUEUE_NAME=collect:tasks
COLLECT_BATCH_MAX_URLS=50
COLLECT_AUTO_RETRY_ENABLED=true
COLLECT_MAX_RETRIES=3
COLLECT_RETRY_BASE_DELAY_SECONDS=30
COLLECT_RETRY_MAX_DELAY_SECONDS=600

IMAGE_QUEUE_ENABLED=true
IMAGE_QUEUE_NAME=image:tasks
IMAGE_WORKER_CONCURRENCY=2
IMAGE_TASK_TIMEOUT_SECONDS=120
IMAGE_AUTO_RETRY_ENABLED=true
IMAGE_MAX_RETRIES=2
IMAGE_RETRY_BASE_DELAY_SECONDS=30
IMAGE_RETRY_MAX_DELAY_SECONDS=300

ORDER_SYNC_QUEUE_ENABLED=true
ORDER_SYNC_QUEUE_NAME=order:sync:tasks
ORDER_SYNC_WORKER_CONCURRENCY=1
ORDER_SYNC_TASK_TIMEOUT_SECONDS=120

CUSTOMER_MESSAGE_SYNC_QUEUE_ENABLED=true
CUSTOMER_MESSAGE_SYNC_QUEUE_NAME=customer:message:sync:tasks
CUSTOMER_MESSAGE_SYNC_WORKER_CONCURRENCY=1
CUSTOMER_MESSAGE_SYNC_TASK_TIMEOUT_SECONDS=120

PRODUCT_PUBLISH_QUEUE_ENABLED=true
PRODUCT_PUBLISH_QUEUE_NAME=product:publish:tasks
PRODUCT_PUBLISH_WORKER_CONCURRENCY=1
PRODUCT_PUBLISH_TASK_TIMEOUT_SECONDS=180

INVENTORY_SYNC_QUEUE_ENABLED=true
INVENTORY_SYNC_QUEUE_NAME=inventory:sync:tasks
INVENTORY_SYNC_WORKER_CONCURRENCY=1
INVENTORY_SYNC_TASK_TIMEOUT_SECONDS=120

COLLECT_TASK_TIMEOUT_SECONDS=600

WORKER_HEARTBEAT_ENABLED=true
WORKER_HEARTBEAT_INTERVAL_SECONDS=10
WORKER_STALE_AFTER_SECONDS=30
WORKER_REAPER_ENABLED=true
WORKER_REAPER_INTERVAL_SECONDS=15
WORKER_LEGACY_RUNNING_TIMEOUT_SECONDS=1800

TASK_ALERT_SCAN_ENABLED=false
TASK_ALERT_SCAN_INTERVAL_SECONDS=60
TASK_ALERT_SCAN_LOOKBACK_MINUTES=120
TASK_ALERT_SCAN_LOCK_TTL_SECONDS=120

UPLOAD_MAX_MB=10

# -----------------------------------------------------------------------------
# 可选：修改 compose 对外映射端口（默认 admin 8000 / backend 8080 / collector 3001 / pg 5432 / redis 6379）
# ADMIN_PUBLISH_PORT=8000
# BACKEND_PUBLISH_PORT=8080
# COLLECTOR_PUBLISH_PORT=3001
# POSTGRES_PUBLISH_PORT=5432
# REDIS_PUBLISH_PORT=6379
# -----------------------------------------------------------------------------
