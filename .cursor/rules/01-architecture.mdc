   │     ├── doubao
   │     ├── gemini
   │     ├── claude
   │     └── ollama
   │
   ├── Image Provider
   │     ├── local
   │     ├── removebg
   │     ├── openai-image
   │     ├── comfyui
   │     ├── flux
   │     └── jimeng
   │
   ├── Platform Provider
   │     ├── tiktok
   │     ├── shopee
